# Ignorer alt
*
!.gitignore

# Unntatt themes, mu-plugins og plugins
!themes/
!themes/**

# Must-use plugins (egenutviklede)
!mu-plugins/
!mu-plugins/**

# Lokal-only mu-plugins (underscore-prefix) — ALDRI push til prod.
# Brukes for ting som skal kjøre kun på localhost (f.eks. e-post-
# blokkering, debug-helpers). Disse må aldri leve på Servebolt.
mu-plugins/_local-*.php

# Egenutviklet plugin
!plugins/
plugins/*
!plugins/bim-verdi-core/
!plugins/bim-verdi-core/**

# Ignorer common files
**/node_modules/
**/vendor/
**/.DS_Store

# Ignorer dist UNNTATT theme dist (kompilert CSS)
plugins/**/dist/
!themes/bimverdi-theme/dist/
!themes/bimverdi-theme/dist/**

# Shared context - not deployed to production
shared-context/

# Claude Code config (versjonskontrollert)
!.claude/
!.claude/**
.claude/local-dev.json
.claude/settings.local.json

# Prosjektdokumentasjon for Claude
!_claude/
!_claude/**

# Worklog (blokkeres fra public via .htaccess)
!WORKLOG.md
!.htaccess

# Composer-avhengigheter (PSL + andre wp-content-pakker)
!composer.json
!composer.lock

# Cached Public Suffix List for jeremykendall/php-domain-parser
!vendor-data/
!vendor-data/**
